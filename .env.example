# ===== Mẫu biến môi trường — copy thành .env (local) và đặt trên Vercel (prod) =====
# .env đã nằm trong .gitignore — KHÔNG commit giá trị thật.

# --- Supabase Postgres (Settings → Database → Connection string) ---
# DATABASE_URL: dùng pooler (Transaction, port 6543) cho app runtime.
DATABASE_URL="postgresql://postgres.<ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: kết nối trực tiếp (port 5432) cho prisma migrate.
DIRECT_URL="postgresql://postgres.<ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth (tự xây) ---
# Chuỗi ngẫu nhiên >= 32 ký tự. Tạo: openssl rand -base64 48
AUTH_SECRET="đổi-thành-chuỗi-ngẫu-nhiên-dài"

# --- Supabase Storage (Settings → API) ---
SUPABASE_URL="https://<ref>.supabase.co"
# service_role key — BÍ MẬT, chỉ dùng phía server.
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"
