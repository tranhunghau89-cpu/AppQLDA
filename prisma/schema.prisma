// Prisma schema — AppQLDA Web (Quản lý dự án kết cấu thép)
// SQLite KHÔNG hỗ trợ enum → các trường "enum" lưu String,
// giá trị hợp lệ + nhãn định nghĩa ở src/lib/constants.ts (validate bằng Zod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("SALES") // ADMIN | SALES | ENGINEERING | PROCUREMENT
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id            String    @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  address       String?
  note          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
}

model Supplier {
  id            String            @id @default(cuid())
  name          String
  category      String            @default("KHAC") // KCT|XA_GO|TON|BL_NEO|BLLK|LAP_DUNG|KHAC
  contactPerson String?
  phone         String?
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  projectLinks   ProjectSupplier[]
  estimateItems  EstimateItem[]
  purchaseOrders PurchaseOrder[]
}

model Project {
  id           String            @id @default(cuid())
  code         String            @unique // N037...
  name         String // K25L60
  buildingType String? // Xưởng, Nhà xưởng...
  status       String            @default("CHO") // CHO|SHOP|GIA_CONG|LAP_DUNG|HOAN_THANH
  location     String?
  customerId   String?
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  startDate    DateTime?
  endDate      DateTime?
  kK           Float? // bước khung K
  kL           Float? // chiều dài L
  kH           Float? // chiều cao H
  area         Float? // m2
  salePrice    Float? // giá bán / hợp đồng
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  suppliers      ProjectSupplier[]
  milestones     Milestone[]
  weeklyLogs     WeeklyLog[]
  estimateItems  EstimateItem[]
  contracts      Contract[]
  purchaseOrders PurchaseOrder[]
  costSummary    CostSummary?
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orderNo      String? // số/tên đơn
  orderDate    DateTime?
  category     String // BL | TON | PANEL | CUALUA | PK | KHAC
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status       String    @default("DRAFT") // DRAFT | ORDERED | RECEIVED
  orderedDate  DateTime?
  receivedDate DateTime?
  value        Float? // Σ thành tiền
  totalWeight  Float? // Σ trọng lượng (kg)
  filePath     String?
  note         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  orderId   String
  order     PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  category  String? // loại sheet: BLLK, Tôn mái, Diềm...
  groupName String? // hạng mục: HM Khung mái...
  name      String
  unit      String?
  qty       Float?
  unitPrice Float?
  amount    Float?
  weight    Float? // kg
  note      String?
  sortOrder Int           @default(0)

  images PoItemImage[]
}

model PoItemImage {
  id        String            @id @default(cuid())
  itemId    String
  item      PurchaseOrderItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  mime      String            @default("image/png")
  data      Bytes // ảnh biên dạng nhúng từ file đơn
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
}

model Contract {
  id             String         @id @default(cuid())
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractNo     String? // Số HĐ: 0704/2026/HĐMB...
  signDate       DateTime? // ngày ký
  subject        String? // V/v: cung cấp & thi công nhà thép...
  partyAName     String? // Bên A (CĐT)
  partyAInfo     String? // địa chỉ, MST, người đại diện
  valueBeforeVat Float? // giá trị chưa VAT = Σ hạng mục
  vatPercent     Float?         @default(8)
  valueWithVat   Float? // tổng có VAT
  paymentTerms   String? // các đợt thanh toán
  filePath       String? // đường dẫn file HĐ đã ký
  status         String         @default("QUOTE") // QUOTE | SIGNED | LIQUIDATED
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  items ContractItem[]
}

model ContractItem {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name       String // hạng mục: Khung mái, Vách, Panel...
  unit       String? // m2
  qty        Float? // khối lượng / diện tích
  unitPrice  Float? // đơn giá bán
  amount     Float? // thành tiền
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

model ProjectSupplier {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  component  String // KCT|XA_GO|TON|BL_NEO|BLLK|LAP_DUNG

  @@unique([projectId, component])
}

model Milestone {
  id         String    @id @default(cuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type       String // BV_KT|SHOP|MUA_HANG|GIA_CONG|LAP_DUNG|LOP_TON|HS_NT|HS_QT
  planDate   DateTime?
  actualDate DateTime?
  done       Boolean   @default(false)
  note       String?

  @@unique([projectId, type])
}

model WeeklyLog {
  id             String  @id @default(cuid())
  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  year           Int
  week           Int
  statusSnapshot String?
  note           String?

  @@unique([projectId, year, week])
}

model EstimateItem {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groupCode      String // KCT|XA_GO|TON|BL_NEO|BLLK|VT_PHU|NHAN_CONG|VAN_CHUYEN|MAY|KHAC
  name           String
  unit           String?
  designQty      Float?
  actualQty      Float?
  unitPrice      Float?
  amount         Float?
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderStatus    String? // Đặt hàng
  dispatchStatus String? // Xuất hàng
  note           String?
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
}

// ----- Tổng hợp chi phí (quyết toán thực tế) -----
model CostSummary {
  id               String         @id @default(cuid())
  projectId        String         @unique
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revenue          Float? // Doanh Thu
  cost             Float? // Chi phí
  profit           Float? // LNTT
  extraVat         Float? // VAT được nhận thêm
  paidWithVat      Float? // Đã Chi cả V
  collectedWithVat Float? // Đã Thu cả V
  receivable       Float? // Còn Phải thu
  collectionNote   String? // vd "đã thu đủ"
  filePath         String? // đường dẫn file THCP gốc
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  categories       CostCategory[]
}

model CostCategory {
  id        String      @id @default(cuid())
  summaryId String
  summary   CostSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  code      String // A..K
  groupCode String // map ESTIMATE_GROUP: KCT|XA_GO|TON|...
  name      String
  supplier  String? // NCC
  value     Float? // GIÁ TRỊ
  payment   Float? // THANH TOÁN
  invoice   Float? // HÓA ĐƠN
  sortOrder Int         @default(0)
  items     CostItem[]
}

model CostItem {
  id         String       @id @default(cuid())
  categoryId String
  category   CostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String // Hạng Mục
  qty        Float? // Khối lượng
  unitPrice  Float? // Đơn giá
  amount     Float? // Thành tiền
  ref        String? // Thời gian / HĐ
  note       String? // Ghi chú
  sortOrder  Int          @default(0)
}
